{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "skipLibCheck": true
  },
  "include": [
    "sysLingoWorld/modShell/game-engine/**/*.js",
    "sysLingoWorld/modShell/content-package/**/*.js",
    "sysLingoWorld/modShell/content-base/**/*.js",
    "server.mjs"
  ],
  "exclude": [
    ".codex/**"
  ]
}
